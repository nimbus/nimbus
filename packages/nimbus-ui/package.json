{
  "name": "nimbus-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "convex codegen --app . && node scripts/generate-routes.mjs",
    "dev": "vite",
    "build": "npm run codegen && tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "npm run codegen && tsc -p tsconfig.json --noEmit",
    "typecheck": "npm run test",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@tanstack/react-router": "1.169.2",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "convex": "*",
    "lucide-react": "1.16.0",
    "nimbus": "*",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shiki": "4.0.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/router-plugin": "1.167.35",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.13"
  }
}
