{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nimbus/nimbus/blob/main/tests/runtime/node/schemas/rust-watchpoints.schema.json",
  "title": "Node compatibility Rust watchpoint expectation catalog",
  "type": "object",
  "required": [
    "schema_version",
    "catalog_kind",
    "generated_from",
    "source_path",
    "contract",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "catalog_kind": {
      "const": "node_compat_rust_watchpoint_expectations"
    },
    "generated_from": {
      "const": "rust_ignore_attributes"
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "contract": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "test_name",
          "lane",
          "expectation",
          "classification",
          "reason",
          "source_path",
          "source_line",
          "unexpected_pass_action"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "test_name": {
            "type": "string",
            "minLength": 1
          },
          "lane": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "node20",
              "node22",
              "node24",
              null
            ]
          },
          "expectation": {
            "enum": [
              "diagnostic_expected_failure",
              "expected_failure",
              "expected_skip"
            ]
          },
          "classification": {
            "enum": [
              "local_patch_regression",
              "watchpoint"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "source_line": {
            "type": "integer",
            "minimum": 1
          },
          "unexpected_pass_action": {
            "const": "remove_ignore_and_promote_or_reclassify_expectation"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
