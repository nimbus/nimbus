{
  "name": "neovex-workspace",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "workspaces": [
    "packages/convex",
    "packages/firebase",
    "packages/neovex",
    "packages/codegen",
    "packages/mongodb",
    "demos/convex/html",
    "demos/convex/http",
    "demos/convex/node",
    "demos/firebase/html",
    "demos/mongodb/node",
    "demos/neovex/html"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "convex:codegen": "convex codegen --app demos/convex/html",
    "convex:codegen:node": "convex codegen --app demos/convex/node",
    "convex:build": "npm run build",
    "convex:test": "npm run test",
    "convex:typecheck": "npm run typecheck",
    "convex:server:node": "cargo run -p neovex-bin -- start --port 8080 --app-dir ./demos/convex/node",
    "convex:server:html": "cargo run -p neovex-bin -- start --port 8080 --app-dir ./demos/convex/html",
    "convex:server:http": "cargo run -p neovex-bin -- start --port 8080 --app-dir ./demos/convex/http",
    "convex:demo:node": "npm run demo --workspace convex-node",
    "convex:demo:html": "npm run dev --workspace convex-html",
    "convex:demo:http": "npm run dev --workspace convex-http",
    "firebase:server:html": "cargo run -p neovex-bin -- start --port 8080",
    "firebase:demo:html": "npm run dev --workspace firebase-html",
    "neovex:demo:html": "npm run dev --workspace neovex-html"
  }
}
