# Nimbus project-local Codex command policy.
# Keep this file focused on execution policy; keep architecture/process
# guidance in AGENTS.md.

# Safe verification loops for this repo.
prefix_rule(
    pattern = ["cargo", "test"],
    decision = "allow",
    justification = "Focused Rust test runs are a normal verification path here.",
    match = [
        "cargo test -p nimbus-runtime node22_networking_dgram_remaining_batch_fixture -- --nocapture --test-threads=1",
        "cargo test -p nimbus-engine",
    ],
)

prefix_rule(
    pattern = ["cargo", "check"],
    decision = "allow",
    justification = "Rust compile checks are routine and safe.",
    match = [
        "cargo check --workspace",
        "cargo check -p nimbus-runtime",
    ],
)

prefix_rule(
    pattern = ["cargo", "clippy"],
    decision = "allow",
    justification = "Rust lint runs are routine and safe.",
    match = [
        "cargo clippy -p nimbus-runtime --all-targets -- -D warnings",
    ],
)

prefix_rule(
    pattern = ["cargo", "fmt"],
    decision = "allow",
    justification = "Formatting checks are routine and safe.",
    match = [
        "cargo fmt --all --check",
    ],
)

prefix_rule(
    pattern = ["make", "check"],
    decision = "allow",
    justification = "Repo verification entrypoint.",
    match = [
        "make check",
    ],
)

prefix_rule(
    pattern = ["make", "clippy"],
    decision = "allow",
    justification = "Repo lint entrypoint.",
    match = [
        "make clippy",
    ],
)

prefix_rule(
    pattern = ["make", "test"],
    decision = "allow",
    justification = "Repo test entrypoint.",
    match = [
        "make test",
    ],
)

prefix_rule(
    pattern = ["npm", "run", "test"],
    decision = "allow",
    justification = "JS test runs are routine and safe.",
    match = [
        "npm run test",
    ],
)

prefix_rule(
    pattern = ["npm", "run", "build"],
    decision = "allow",
    justification = "JS build verification is routine and safe.",
    match = [
        "npm run build",
    ],
)

prefix_rule(
    pattern = ["npm", "run", "typecheck"],
    decision = "allow",
    justification = "JS typecheck verification is routine and safe.",
    match = [
        "npm run typecheck",
    ],
)

# Read-only git inspection.
prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Read-only worktree inspection.",
    match = [
        "git status --short",
        "git status",
    ],
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Read-only diff inspection.",
    match = [
        "git diff --check",
        "git diff -- AGENTS.md",
    ],
)

prefix_rule(
    pattern = ["git", "show"],
    decision = "allow",
    justification = "Read-only git object inspection.",
    match = [
        "git show HEAD:Cargo.toml",
    ],
)

prefix_rule(
    pattern = ["git", "rev-parse"],
    decision = "allow",
    justification = "Read-only git revision inspection.",
    match = [
        "git rev-parse HEAD",
    ],
)

prefix_rule(
    pattern = ["git", "describe"],
    decision = "allow",
    justification = "Read-only tag inspection.",
    match = [
        "git describe --tags --exact-match HEAD",
    ],
)

# Prompt before commands that mutate published history, dependency state, or
# package installation.
prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing branches or tags should stay intentional.",
    match = [
        "git push origin main",
        "git push --tags",
    ],
)

prefix_rule(
    pattern = ["git", "tag"],
    decision = "prompt",
    justification = "Tag creation should stay intentional.",
    match = [
        "git tag v2.7.14-locker.33",
    ],
)

prefix_rule(
    pattern = ["cargo", "update"],
    decision = "prompt",
    justification = "Dependency graph changes should stay intentional.",
    match = [
        "cargo update -p deno_node",
    ],
)

prefix_rule(
    pattern = ["cargo", "add"],
    decision = "prompt",
    justification = "Adding Rust dependencies should stay intentional.",
    match = [
        "cargo add anyhow",
    ],
)

prefix_rule(
    pattern = ["npm", "install"],
    decision = "prompt",
    justification = "Installing JS dependencies should stay intentional.",
    match = [
        "npm install",
        "npm install typescript",
    ],
)

# Block common destructive commands by default.
prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard worktree state; inspect and edit intentionally instead.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD",
    ],
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Avoid destructive recursive deletion from Codex.",
    match = [
        "rm -rf target",
        "rm -rf /tmp/example",
    ],
)

prefix_rule(
    pattern = ["sudo"],
    decision = "forbidden",
    justification = "Use normal sandbox approval flows instead of sudo.",
    match = [
        "sudo make install",
    ],
)
